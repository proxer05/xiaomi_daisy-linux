###############################################################################
# example-network.config — Template for user-specific network settings
#
# Copy this file to network.config and edit the values to match your setup:
#   cp example-network.config network.config
#
# network.config is .gitignored and will not be committed.
###############################################################################

# --- Wi-Fi ---
# Your Wi-Fi network name and password
WIFI_SSID="MyWiFiNetwork"
WIFI_PASS="MyWiFiPassword"
# ISO 3166-1 alpha-2 country code for regulatory domain
WIFI_COUNTRY="US"

# --- Static IP for wlan0 ---
# Set the phone's Wi-Fi static IP, gateway, and DNS servers.
# Use CIDR notation for the address.
WLAN_ADDRESS="192.168.1.100/24"
WLAN_GATEWAY="192.168.1.1"
WLAN_DNS="8.8.8.8 8.8.4.4"

# --- USB RNDIS gadget (usb0) ---
# The phone acts as a USB ethernet gadget with a built-in DHCP server.
# Your PC will automatically get an IP from the pool when connected via USB.
USB_ADDRESS="172.16.42.1/24"
USB_DHCP_POOL_OFFSET=100
USB_DHCP_POOL_SIZE=50
USB_DNS="8.8.8.8 8.8.4.4"

# --- Proxmox bridge (vmbr0) — only used with --with-pxvirt ---
# Internal NAT bridge for LXC containers and VMs.
# Containers get IPs from this subnet via the built-in DHCP server.
VMBR_ADDRESS="10.10.10.1/24"
VMBR_DHCP_POOL_OFFSET=100
VMBR_DHCP_POOL_SIZE=100
VMBR_DNS="8.8.8.8 8.8.4.4"

# --- Timezone ---
# See: timedatectl list-timezones
TIMEZONE="UTC"
